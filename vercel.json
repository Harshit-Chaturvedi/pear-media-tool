{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ],
  "env": {
    "HF_API_KEY": "@hf_api_key",
    "COHERE_API_KEY": "@cohere_api_key",
    "STABILITY_API_KEY": "@stability_api_key",
    "GEMINI_API_KEY": "@gemini_api_key"
  }
}
